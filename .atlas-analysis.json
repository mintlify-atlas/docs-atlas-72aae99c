  "keyFeatures": [
    "Attendance tracking with clock in/out",
    "Break and pause management",
    "Kiosk mode for self-service time registration",
    "Photo capture on attendance registration",
    "Manual attendance entry by administrators",
    "Employee management with organizational structure",
    "Role-based access control with JWT authentication",
    "Multi-unit support with zone management",
    "Operational schedules configuration",
    "Credentials and badges management",
    "Observations and audit system",
    "Excel report generation for payroll",
    "Attendance inconsistency detection",
    "Password reset and user registration flows",
    "OpenAPI/Swagger documentation"
